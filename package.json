{
  "name": "solid-js",
  "description": "A declarative JavaScript library for building user interfaces.",
  "version": "1.0.0",
  "author": "Ryan Carniato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/solidjs/solid"
  },
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "test": "turbo run test test-types --filter=!test-integration",
    "test:integration": "turbo run test --filter=test-integration",
    "coverage": "turbo run coverage",
    "build": "turbo run build",
    "types": "turbo run types",
    "publish": "pnpm run build && pnpm run types && pnpm run release:only",
    "bump": "changeset add",
    "release:only": "changeset publish",
    "format": "prettier --write --cache \"**/*.[tj]s?(x)\""
  },
  "devDependencies": {
    "@babel/cli": "^7.18.9",
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.18.9",
    "@babel/preset-typescript": "^7.18.6",
    "@changesets/cli": "^2.25.2",
    "@codspeed/vitest-plugin": "^5.4.0",
    "@dom-expressions/babel-plugin-jsx": "0.50.0-next.22",
    "@dom-expressions/compiler": "link:../dom-expressions/packages/compiler",
    "@dom-expressions/hyperscript": "0.50.0-next.22",
    "@dom-expressions/runtime": "0.50.0-next.22",
    "@dom-expressions/tagged-jsx": "0.50.0-next.22",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-replace": "^5.0.2",
    "@types/node": "^25.0.8",
    "@vitest/coverage-v8": "^4.1.6",
    "babel-plugin-transform-rename-import": "^2.3.0",
    "coveralls": "^3.1.1",
    "csstype": "^3.1.0",
    "jsdom": "^25.0.1",
    "ncp": "^2.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "rimraf": "^3.0.2",
    "rollup": "^4.24.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-copy": "^3.4.0",
    "seroval": "~1.5.4",
    "simple-git-hooks": "^2.8.1",
    "symlink-dir": "^5.0.1",
    "tsconfig-replace-paths": "^0.0.11",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3",
    "vite-plugin-solid": "3.0.0-next.4",
    "vitest": "^4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "sh scripts/pre-commit.sh"
  },
  "engines": {
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.1"
}
